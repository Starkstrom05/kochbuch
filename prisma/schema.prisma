generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("MEMBER")
  familyId      String?
  family        Family?        @relation(fields: [familyId], references: [id])
  activeCookbookId String?
  activeCookbook   Cookbook?    @relation("UserActiveCookbook", fields: [activeCookbookId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  recipes       Recipe[]
  ratings       Rating[]
  shoppingLists ShoppingList[]
  mealPlans     MealPlan[]
  pantry        PantryItem[]
  frequentItems FrequentItem[]
  shoppingListAccesses ShoppingListAccess[] @relation("ShoppingListMember")
  shoppingListGrants   ShoppingListAccess[] @relation("ShoppingListGranter")
  sessions      Session[]
  accounts      Account[]
  ourGroceries  UserOurGroceriesCredentials?
  cookbooks         Cookbook[]       @relation("CookbookOwner")
  cookbookAccesses  CookbookAccess[] @relation("CookbookViewer")
  cookbookGrants    CookbookAccess[] @relation("CookbookGranter")

  @@index([familyId])
  @@index([activeCookbookId])
}

// Cookbook: persoenliche Rezeptsammlung eines Users. Owner hat Schreibrecht,
// Viewer (via CookbookAccess) nur Leserecht. Admin (User.role = "ADMIN")
// hat Schreibrecht auf ALLE Cookbooks.
model Cookbook {
  id             String           @id @default(cuid())
  ownerId        String
  owner          User             @relation("CookbookOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name           String
  coverImagePath String?
  accentColor    String?
  inkColor       String?
  paperColor     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  recipes        Recipe[]
  accesses       CookbookAccess[]
  activeViewers  User[]           @relation("UserActiveCookbook")

  @@index([ownerId])
}

model CookbookAccess {
  id          String   @id @default(cuid())
  cookbookId  String
  userId      String
  grantedById String
  grantedAt   DateTime @default(now())
  cookbook    Cookbook @relation(fields: [cookbookId], references: [id], onDelete: Cascade)
  user        User     @relation("CookbookViewer", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User     @relation("CookbookGranter", fields: [grantedById], references: [id])

  @@unique([cookbookId, userId])
  @@index([userId])
}

// Mandant: eine Familie/ein Haushalt. Branding-Spalten werden in Phase 8e genutzt.
model Family {
  id             String   @id @default(cuid())
  name           String
  coverImagePath String?
  accentColor    String?
  inkColor       String?
  paperColor     String?
  createdAt      DateTime @default(now())
  members        User[]
  categories     Category[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipe {
  id              String             @id @default(cuid())
  title           String
  slug            String             @unique
  description     String?
  servings        Int                @default(4)
  prepMinutes     Int?
  cookMinutes     Int?
  difficulty      Int?
  sourceUrl       String?
  sourceType      String             @default("MANUAL")
  instructions    String
  notes           String?
  handwrittenPath String?
  isPublic        Boolean            @default(false)
  isActive        Boolean            @default(true)
  shareToken      String?            @unique
  tags            String?
  cookbookId      String
  cookbook        Cookbook           @relation(fields: [cookbookId], references: [id], onDelete: Cascade)
  // Quellen-Vermerk fuer importierte Rezepte (Vollkopie aus fremdem Cookbook)
  importedFromRecipeId   String?
  importedFromRecipe     Recipe?     @relation("RecipeImportSource", fields: [importedFromRecipeId], references: [id], onDelete: SetNull)
  importedFromRecipeCopies Recipe[]  @relation("RecipeImportSource")
  importedFromCookbookId String?
  importedFromUserId     String?
  // Optionale Nährwert-Override pro Portion (überschreibt die Auto-Schätzung)
  nutritionKcal     Float?
  nutritionProteinG Float?
  nutritionCarbsG   Float?
  nutritionFatG     Float?
  createdById     String
  createdBy       User               @relation(fields: [createdById], references: [id])
  ingredients     RecipeIngredient[]
  categories      CategoryOnRecipe[]
  ratings         Rating[]
  images          RecipeImage[]
  steps           RecipeStep[]
  mealPlanEntries MealPlanEntry[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([createdById])
  @@index([title])
  @@index([sourceUrl])
  @@index([updatedAt])
  @@index([isActive])
  @@index([cookbookId])
  @@index([importedFromRecipeId])
}

model RecipeImage {
  id        String   @id @default(cuid())
  recipeId  String
  path      String
  order     Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, order])
}

model RecipeStep {
  id              String  @id @default(cuid())
  recipeId        String
  position        Int
  text            String
  durationSeconds Int?
  recipe          Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, position])
  @@index([recipeId])
}

model Ingredient {
  id        String               @id @default(cuid())
  name      String               @unique
  aliases   String?
  category  String?
  density   Float?
  uses      RecipeIngredient[]
  pantry    PantryItem[]
  nutrition IngredientNutrition?
}

// Nährwerte je 100 g (Masse-Basis). Für Volumen-Zutaten wird über
// Ingredient.density (g/ml) auf Gramm umgerechnet.
model IngredientNutrition {
  id           String     @id @default(cuid())
  ingredientId String     @unique
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  kcal         Float
  proteinG     Float?
  carbsG       Float?
  fatG         Float?
  fiberG       Float?
}

model PantryItem {
  id           String     @id @default(cuid())
  ownerId      String
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       Float?
  unit         String?
  addedAt      DateTime   @default(now())

  @@unique([ownerId, ingredientId])
  @@index([ownerId])
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  amount       Float?
  unit         String?
  note         String?
  group        String?
  order        Int        @default(0)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([recipeId])
}

model Category {
  id       String             @id @default(cuid())
  name     String             @unique
  icon     String?
  // null = global (für alle Familien sichtbar); sonst nur für die eigene Familie
  familyId String?
  family   Family?            @relation(fields: [familyId], references: [id])
  recipes  CategoryOnRecipe[]

  @@index([familyId])
}

model CategoryOnRecipe {
  recipeId   String
  categoryId String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([recipeId, categoryId])
  @@index([categoryId])
}

model Rating {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([recipeId, userId])
  // recipeId-only Lookups (z. B. `GROUP BY recipeId` im Search-Path) profitieren
  // vom Composite-Unique-Prefix; userId-only („alle Bewertungen eines Users")
  // braucht einen eigenen Index.
  @@index([userId])
}

model ShoppingList {
  id        String               @id @default(cuid())
  name      String
  ownerId   String
  owner     User                 @relation(fields: [ownerId], references: [id])
  items     ShoppingItem[]
  accesses  ShoppingListAccess[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([ownerId])
}

// Freigabe einer Einkaufsliste an ein weiteres Mitglied (analog CookbookAccess).
// Anders als bei Cookbooks haben Mitglieder VOLLE Bearbeitung (Items hinzufuegen/
// abhaken/notieren); nur Owner/Admin verwalten Freigaben und loeschen die Liste.
model ShoppingListAccess {
  id          String       @id @default(cuid())
  listId      String
  userId      String
  grantedById String
  grantedAt   DateTime     @default(now())
  list        ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user        User         @relation("ShoppingListMember", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User         @relation("ShoppingListGranter", fields: [grantedById], references: [id])

  @@unique([listId, userId])
  @@index([userId])
}

model ShoppingItem {
  id        String       @id @default(cuid())
  listId    String
  name      String
  amount    Float?
  unit      String?
  checked   Boolean      @default(false)
  recipeRef String?
  note      String?
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

// "Haeufig gekauft": pro User aggregierte Historie manuell hinzugefuegter
// Items. count + lastUsedAt treiben das Ranking der Master-List; unit merkt
// sich die zuletzt genutzte Einheit fuer 1-Tap-Wiederhinzufuegen.
model FrequentItem {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  unit       String?
  count      Int      @default(1)
  lastUsedAt DateTime @default(now())

  @@unique([ownerId, name])
  @@index([ownerId])
}

model MealPlan {
  id           String          @id @default(cuid())
  name         String
  ownerId      String
  firstDay     Int             @default(1)
  familyShared Boolean         @default(false)
  weekStart    DateTime
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  entries   MealPlanEntry[]

  @@index([ownerId])
}

model MealPlanEntry {
  id       String   @id @default(cuid())
  planId   String
  recipeId String
  dayIndex Int
  mealType String
  servings Int
  order    Int      @default(0)
  plan     MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@index([recipeId])
}

model AppMeta {
  key   String @id
  value String
}

// OurGroceries-Bruecke: pro User verschluesselte Zugangsdaten + gewaehlte
// Ziel-Liste. Klartext-Username/Passwort wird AES-256-GCM-verschluesselt
// (Key aus OURGROCERIES_ENCRYPTION_KEY). Siehe CLAUDE.md "Bewusste Ausnahmen
// vom Lokal-First-Prinzip".
model UserOurGroceriesCredentials {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedSecret Bytes
  iv              Bytes
  authTag         Bytes
  defaultListId   String?
  defaultListName String?
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
