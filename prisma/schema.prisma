generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("MEMBER")
  createdAt     DateTime       @default(now())
  recipes       Recipe[]
  ratings       Rating[]
  shoppingLists ShoppingList[]
  mealPlans     MealPlan[]
  pantry        PantryItem[]
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipe {
  id              String             @id @default(cuid())
  title           String
  slug            String             @unique
  description     String?
  servings        Int                @default(4)
  prepMinutes     Int?
  cookMinutes     Int?
  difficulty      Int?
  sourceUrl       String?
  sourceType      String             @default("MANUAL")
  instructions    String
  notes           String?
  handwrittenPath String?
  isPublic        Boolean            @default(false)
  isActive        Boolean            @default(true)
  shareToken      String?            @unique
  tags            String?
  createdById     String
  createdBy       User               @relation(fields: [createdById], references: [id])
  ingredients     RecipeIngredient[]
  categories      CategoryOnRecipe[]
  ratings         Rating[]
  images          RecipeImage[]
  steps           RecipeStep[]
  mealPlanEntries MealPlanEntry[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([createdById])
  @@index([title])
  @@index([sourceUrl])
  @@index([updatedAt])
  @@index([isActive])
}

model RecipeImage {
  id        String   @id @default(cuid())
  recipeId  String
  path      String
  order     Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, order])
}

model RecipeStep {
  id              String  @id @default(cuid())
  recipeId        String
  position        Int
  text            String
  durationSeconds Int?
  recipe          Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, position])
  @@index([recipeId])
}

model Ingredient {
  id        String             @id @default(cuid())
  name      String             @unique
  aliases   String?
  category  String?
  density   Float?
  uses      RecipeIngredient[]
  pantry    PantryItem[]
}

model PantryItem {
  id           String     @id @default(cuid())
  ownerId      String
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       Float?
  unit         String?
  addedAt      DateTime   @default(now())

  @@unique([ownerId, ingredientId])
  @@index([ownerId])
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  amount       Float?
  unit         String?
  note         String?
  group        String?
  order        Int        @default(0)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([recipeId])
}

model Category {
  id      String             @id @default(cuid())
  name    String             @unique
  icon    String?
  recipes CategoryOnRecipe[]
}

model CategoryOnRecipe {
  recipeId   String
  categoryId String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([recipeId, categoryId])
  @@index([categoryId])
}

model Rating {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([recipeId, userId])
}

model ShoppingList {
  id        String         @id @default(cuid())
  name      String
  ownerId   String
  owner     User           @relation(fields: [ownerId], references: [id])
  items     ShoppingItem[]
  createdAt DateTime       @default(now())

  @@index([ownerId])
}

model ShoppingItem {
  id        String       @id @default(cuid())
  listId    String
  name      String
  amount    Float?
  unit      String?
  checked   Boolean      @default(false)
  recipeRef String?
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

model MealPlan {
  id        String          @id @default(cuid())
  name      String
  ownerId   String
  firstDay  Int             @default(1)
  weekStart DateTime
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  entries   MealPlanEntry[]

  @@index([ownerId])
}

model MealPlanEntry {
  id       String   @id @default(cuid())
  planId   String
  recipeId String
  dayIndex Int
  mealType String
  servings Int
  order    Int      @default(0)
  plan     MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@index([recipeId])
}

model AppMeta {
  key   String @id
  value String
}
