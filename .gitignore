# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite (dev DB only — production DBs live in volumes)
/prisma/dev.db
/prisma/dev.db-journal
# WAL-Sidecar-Dateien (SQLite läuft im WAL-Modus)
/prisma/dev.db-shm
/prisma/dev.db-wal
/prisma/migrations/dev.db
# Prisma 7 resolves relative file: URLs from cwd — guard a stray root dev.db
/dev.db
/dev.db-journal

# uploads
/uploads
/data

# E2E auth artifact (contains session cookie)
/e2e/.auth.json

# Image exports built by scripts/build-and-save.sh
/kochbuch-image-*.tar.gz

# editor
.vscode/*
!.vscode/extensions.json
.idea/

# Claude Code local working files
/.claude/

# Stray SQLite memory-URL files created when a tool falls back to file::memory:
:memory:*
