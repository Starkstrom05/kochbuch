DATABASE_URL="file:./prisma/dev.db"

# NextAuth — fuer dev `openssl rand -base64 32`
AUTH_SECRET="change-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Ollama (in Docker: http://ollama:11434, lokal: http://localhost:11434)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b-instruct-q4_K_M"

# Upload-Verzeichnis (lokal relativ, in Docker: /data/images)
UPLOAD_DIR="./uploads"

# Puppeteer (in Docker: /usr/bin/chromium)
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"

# App-Version (wird von package.json gelesen, hier nur fuer Override im Container)
# KOCHBUCH_VERSION="0.1.0"
