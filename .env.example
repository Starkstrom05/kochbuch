DATABASE_URL="file:./prisma/dev.db"

# NextAuth — fuer dev `openssl rand -base64 32`
AUTH_SECRET="change-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Ollama (in Docker: http://ollama:11434, lokal: http://localhost:11434)
OLLAMA_BASE_URL="http://localhost:11434"
# NAS-CPU ist schwach (Celeron N5095) → kleines Modell waehlen
# Phi-3-mini ist ein guter Kompromiss zwischen Qualitaet und Geschwindigkeit
OLLAMA_MODEL="phi3:3.8b-mini-4k-instruct-q4_K_M"

# Upload-Verzeichnis (lokal relativ, in Docker: /data/images)
UPLOAD_DIR="./uploads"

# Puppeteer (in Docker: /usr/bin/chromium)
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"

# Interne App-URL fuer Puppeteer (in Docker: http://localhost:3000)
# APP_URL="http://localhost:3000"

# Optional: Puppeteer-Sidecar (Browserless) statt lokalem Chromium. Ist diese
# Variable gesetzt, verbindet sich die App per WebSocket statt Chromium zu starten.
# Siehe docs/PUPPETEER-SIDECAR.md. Bei Sidecar APP_URL auf den Compose-Hostnamen
# setzen (z.B. http://app:3000), sonst erreicht Browserless die App nicht.
# PUPPETEER_WS_URL="ws://browserless:3000?token=<BROWSERLESS_TOKEN>"

# App-Version (wird von package.json gelesen, hier nur fuer Override im Container)
# KOCHBUCH_VERSION="0.1.0"
