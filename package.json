{
  "name": "kochbuch",
  "version": "0.17.1",
  "private": true,
  "description": "Familien-Kochbuch im Mery-Design (Next.js + Prisma + Ollama)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "puppeteer": "^24.43.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-pageflip": "^2.0.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,css,md}": "prettier --write"
  }
}
